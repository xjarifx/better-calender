{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es2017", "dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["jest"]
  },
  "include": ["tests/**/*.ts", "app/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules"]
}
